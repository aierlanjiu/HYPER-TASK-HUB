# 🌐 HyperTask Hub - Environment Example
# Copy this file to .env and fill in your real credentials.

# --- Agent Backend & Models ---
# The endpoint for your DeepSeek API (e.g., Local NAS or DeepSeek Official)
DEEPSEEK_API_URL=http://localhost:6799/v1/chat/completions
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_KEY_HERE

# Path to local CLI tools
GEMINI_CLI=/opt/homebrew/bin/gemini
OPENCLAW_CLI=/opt/homebrew/bin/openclaw

# --- Infrastructure ---
HUB_HOST=0.0.0.0
HUB_PORT=8000

# --- Supervisor Bot (Telegram) ---
# Get your token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
# Your numeric Telegram user ID (for admin commands)
ALLOWED_TELEGRAM_IDS=123456789,987654321
# The group or user ID where task approvals will be sent
DEFAULT_TELEGRAM_CHAT_ID=YOUR_CHAT_ID_HERE
# Proxy settings for users in restricted network areas
TELEGRAM_PROXY=http://127.0.0.1:7897

# --- Other Integrations ---
DISCORD_TOKEN=YOUR_DISCORD_TOKEN_HERE
